# ════════════════════════════════════════════════════════════════════
#  NEXTWAY School Management System — API Environment Variables
#  Copy this file to .env and fill in your actual values
#  NEVER commit .env to version control
# ════════════════════════════════════════════════════════════════════

# ── SERVER ───────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# Frontend URL (for CORS whitelist)
# Development:
CLIENT_URL=http://localhost:5173
# Production: CLIENT_URL=https://yourdomain.com

# ── MONGODB ──────────────────────────────────────────────────────────
# Local MongoDB (non-SRV):
MONGODB_URI=mongodb://localhost:27017/nextway_sms

# MongoDB Atlas (SRV) — uncomment and fill:
# MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/nextway_sms?retryWrites=true&w=majority

# ── JWT SECRETS ───────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_64_CHAR_RANDOM_STRING_FOR_ACCESS_TOKEN_SIGNING
JWT_REFRESH_SECRET=REPLACE_WITH_DIFFERENT_64_CHAR_RANDOM_STRING_FOR_REFRESH_TOKEN

JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ── FILE UPLOADS ──────────────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10

# Cloudinary (optional — for cloud file storage in production)
# CLOUDINARY_CLOUD_NAME=your_cloud_name
# CLOUDINARY_API_KEY=your_api_key
# CLOUDINARY_API_SECRET=your_api_secret

# ── AI DOUBT SOLVER ───────────────────────────────────────────────────
# Choose one provider: claude | openai | gemini
AI_PROVIDER=claude

# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-REPLACE_WITH_YOUR_ANTHROPIC_KEY

# OpenAI (GPT)
# OPENAI_API_KEY=sk-REPLACE_WITH_YOUR_OPENAI_KEY

# Google (Gemini)
# GEMINI_API_KEY=REPLACE_WITH_YOUR_GEMINI_KEY

# ── RATE LIMITING ─────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MINUTES=15
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_MAX=10

# ── SUPER ADMIN SEED ──────────────────────────────────────────────────
# Used only by npm run seed — change these before first run
SUPER_ADMIN_NAME=Super Admin
SUPER_ADMIN_EMAIL=superadmin@nextway.edu
SUPER_ADMIN_PASSWORD=NexTway@2026!Super

# ── SCHOOL SEED ───────────────────────────────────────────────────────
SCHOOL_NAME=NEXTWAY Academy
SCHOOL_CODE=NWA001
SCHOOL_BOARD=CBSE
SCHOOL_CITY=Indore
SCHOOL_STATE=Madhya Pradesh
SCHOOL_PHONE=+917314000000
SCHOOL_EMAIL=info@nextway.edu.in
